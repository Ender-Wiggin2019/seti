{
  "name": "seti-monorepo",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter @seti/web dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "smoke:web": "./scripts/smoke-web.sh",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": ["biome check --write --diagnostic-level=error"],
    "**/*.{json,css,scss,webmanifest}": ["biome format --write"]
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@commitlint/cli": "^16.3.0",
    "@commitlint/config-conventional": "^16.2.4",
    "lint-staged": "^12.5.0",
    "turbo": "^2.5.8"
  }
}
