{
  "name": "@seti/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "bash ../../scripts/sync-card-assets.sh",
    "dev": "vite",
    "prebuild": "bash ../../scripts/sync-card-assets.sh",
    "build": "bash ../../scripts/sync-card-assets.sh && tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@seti/cards": "workspace:@ender-seti/cards@*",
    "@seti/common": "workspace:@ender-seti/common@*",
    "@tanstack/react-query": "^5.90.7",
    "@tanstack/react-router": "^1.132.23",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^23.16.8",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^13.5.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.18.6",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^26.1.0",
    "msw": "^2.11.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.15",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  }
}
