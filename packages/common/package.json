{
  "name": "@ender-seti/common",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.js",
      "require": "./dist/types/*.cjs"
    },
    "./types/protocol": {
      "types": "./dist/types/protocol/index.d.ts",
      "import": "./dist/types/protocol/index.js",
      "require": "./dist/types/protocol/index.cjs"
    },
    "./types/protocol/*": {
      "types": "./dist/types/protocol/*.d.ts",
      "import": "./dist/types/protocol/*.js",
      "require": "./dist/types/protocol/*.cjs"
    },
    "./data/*": {
      "types": "./dist/data/*.d.ts",
      "import": "./dist/data/*.js",
      "require": "./dist/data/*.cjs"
    },
    "./data/faq": {
      "types": "./dist/data/faq/index.d.ts",
      "import": "./dist/data/faq/index.js",
      "require": "./dist/data/faq/index.cjs"
    },
    "./constant/*": {
      "types": "./dist/constant/*.d.ts",
      "import": "./dist/constant/*.js",
      "require": "./dist/constant/*.cjs"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./dist/utils/*.js",
      "require": "./dist/utils/*.cjs"
    },
    "./rules": {
      "types": "./dist/rules/index.d.ts",
      "import": "./dist/rules/index.js",
      "require": "./dist/rules/index.cjs"
    },
    "./rules/*": {
      "types": "./dist/rules/*.d.ts",
      "import": "./dist/rules/*.js",
      "require": "./dist/rules/*.cjs"
    },
    "./locales/*": "./dist/locales/*"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && mkdir -p dist/locales && cp -R locales/* dist/locales/",
    "clean": "rm -rf dist",
    "lint": "biome check src",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
